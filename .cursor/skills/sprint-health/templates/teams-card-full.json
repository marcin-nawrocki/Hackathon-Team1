{
  "type": "message",
  "attachments": [
    {
      "contentType": "application/vnd.microsoft.card.adaptive",
      "content": {
        "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
        "type": "AdaptiveCard",
        "version": "1.4",
        "body": [
          {
            "type": "TextBlock",
            "size": "Large",
            "weight": "Bolder",
            "text": "{{ragEmoji}} Sprint Health - {{sprintName}}"
          },
          {
            "type": "TextBlock",
            "isSubtle": true,
            "wrap": true,
            "text": "Overall: {{overallStatus}} | Goal: {{goalStatus}} | Day {{daysElapsed}}/{{sprintLength}} ({{daysRemaining}} left)"
          },
          {
            "type": "TextBlock",
            "wrap": true,
            "text": "{{ragJustification}}"
          },
          {
            "type": "TextBlock",
            "isSubtle": true,
            "wrap": true,
            "text": "Tests excluded: {{testExcludedCount}} tickets, {{testExcludedSP}} SP"
          },
          {
            "type": "TextBlock",
            "weight": "Bolder",
            "text": "Sprint Goal Progress"
          },
          {
            "type": "ColumnSet",
            "columns": [
              {
                "type": "Column",
                "width": "stretch",
                "items": [
                  {
                    "type": "TextBlock",
                    "weight": "Bolder",
                    "text": "Theme",
                    "wrap": true
                  }
                ]
              },
              {
                "type": "Column",
                "width": "auto",
                "items": [
                  {
                    "type": "TextBlock",
                    "weight": "Bolder",
                    "text": "SP",
                    "wrap": true
                  }
                ]
              },
              {
                "type": "Column",
                "width": "auto",
                "items": [
                  {
                    "type": "TextBlock",
                    "weight": "Bolder",
                    "text": "%",
                    "wrap": true
                  }
                ]
              },
              {
                "type": "Column",
                "width": "auto",
                "items": [
                  {
                    "type": "TextBlock",
                    "weight": "Bolder",
                    "text": "Status",
                    "wrap": true
                  }
                ]
              }
            ]
          },
          {
            "type": "ColumnSet",
            "columns": [
              {
                "type": "Column",
                "width": "stretch",
                "items": [
                  {
                    "type": "TextBlock",
                    "text": "{{themeName}}",
                    "wrap": true
                  }
                ]
              },
              {
                "type": "Column",
                "width": "auto",
                "items": [
                  {
                    "type": "TextBlock",
                    "text": "{{themeDoneSP}}/{{themeTotalSP}} SP",
                    "wrap": true
                  }
                ]
              },
              {
                "type": "Column",
                "width": "auto",
                "items": [
                  {
                    "type": "TextBlock",
                    "text": "{{themePct}}%",
                    "wrap": true
                  }
                ]
              },
              {
                "type": "Column",
                "width": "auto",
                "items": [
                  {
                    "type": "TextBlock",
                    "text": "{{themeVerdictEmoji}}",
                    "wrap": true
                  }
                ]
              }
            ]
          },
          {
            "type": "TextBlock",
            "wrap": true,
            "text": "Goal roll-up: {{goalDoneSP}}/{{goalTotalSP}} SP ({{goalPct}}%) vs {{expectedPct}}% expected -> {{goalVerdictEmoji}}"
          },
          {
            "type": "TextBlock",
            "weight": "Bolder",
            "text": "Progress Summary"
          },
          {
            "type": "FactSet",
            "facts": [
              {
                "title": "Total SP",
                "value": "{{totalSP}}"
              },
              {
                "title": "Done SP",
                "value": "{{doneSP}} ({{pctComplete}}%)"
              },
              {
                "title": "In Progress SP",
                "value": "{{inProgressSP}} ({{ipPct}}%){{wipWarning}}"
              },
              {
                "title": "To Do SP",
                "value": "{{toDoSP}} ({{todoPct}}%)"
              },
              {
                "title": "Issues",
                "value": "{{issueCount}} (Done {{doneCount}} / IP {{ipCount}} / To Do {{todoCount}})"
              },
              {
                "title": "Unestimated",
                "value": "{{unestimatedCount}}"
              },
              {
                "title": "Tests excluded",
                "value": "{{testExcludedCount}} tickets, {{testExcludedSP}} SP"
              }
            ]
          },
          {
            "type": "TextBlock",
            "weight": "Bolder",
            "text": "Burndown"
          },
          {
            "type": "FactSet",
            "facts": [
              {
                "title": "Ideal remaining",
                "value": "{{idealRemaining}} SP"
              },
              {
                "title": "Actual remaining",
                "value": "{{actualRemaining}} SP"
              },
              {
                "title": "Delta",
                "value": "{{burndownDelta}} SP ({{burndownDeltaPct}}%)"
              },
              {
                "title": "Expected vs Actual",
                "value": "{{expectedComplete}}% / {{actualComplete}}%"
              }
            ]
          },
          {
            "type": "TextBlock",
            "weight": "Bolder",
            "text": "Since Yesterday"
          },
          {
            "type": "TextBlock",
            "wrap": true,
            "text": "{{sinceYesterdayBody}}"
          },
          {
            "type": "TextBlock",
            "weight": "Bolder",
            "text": "Aging / Stuck Tickets"
          },
          {
            "type": "TextBlock",
            "wrap": true,
            "text": "{{agingBody}}"
          },
          {
            "type": "TextBlock",
            "weight": "Bolder",
            "text": "Estimation Notes"
          },
          {
            "type": "TextBlock",
            "wrap": true,
            "text": "{{estimationBody}}"
          },
          {
            "type": "TextBlock",
            "weight": "Bolder",
            "text": "Recommendations"
          },
          {
            "type": "TextBlock",
            "wrap": true,
            "text": "{{recommendationsBody}}"
          }
        ]
      }
    }
  ]
}
