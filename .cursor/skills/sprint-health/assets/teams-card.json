{
  "type": "message",
  "attachments": [
    {
      "contentType": "application/vnd.microsoft.card.adaptive",
      "content": {
        "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
        "type": "AdaptiveCard",
        "version": "1.5",
        "body": [
          {
            "type": "TextBlock",
            "size": "Large",
            "weight": "Bolder",
            "wrap": true,
            "text": "{{ragEmoji}} Sprint Health — {{sprintName}}"
          },
          {
            "type": "TextBlock",
            "isSubtle": true,
            "wrap": true,
            "spacing": "None",
            "text": "Overall: {{overallStatus}} | Goal: {{goalStatus}} | Day {{daysElapsed}}/{{sprintLength}} ({{daysRemaining}} left)"
          },
          {
            "type": "Container",
            "style": "emphasis",
            "bleed": true,
            "items": [
              {
                "type": "TextBlock",
                "weight": "Bolder",
                "text": "TL;DR"
              },
              {
                "type": "TextBlock",
                "wrap": true,
                "spacing": "None",
                "text": "{{tldr}}"
              },
              {
                "type": "TextBlock",
                "wrap": true,
                "isSubtle": true,
                "text": "Verdict: {{oneLineVerdict}}"
              }
            ]
          },
          {
            "type": "TextBlock",
            "wrap": true,
            "text": "**Goal roll-up:** {{goalDoneSP}}/{{goalTotalSP}} SP ({{goalPct}}%) vs {{expectedPct}}% expected -> {{goalVerdictEmoji}}"
          },
          {
            "type": "TextBlock",
            "weight": "Bolder",
            "text": "What matters most"
          },
          {
            "type": "TextBlock",
            "wrap": true,
            "spacing": "None",
            "text": "{{whatMattersBody}}"
          },
          {
            "type": "TextBlock",
            "weight": "Bolder",
            "text": "Top recommendations"
          },
          {
            "type": "TextBlock",
            "wrap": true,
            "spacing": "None",
            "text": "{{recommendationsSummary}}"
          },
          {
            "type": "ActionSet",
            "actions": [
              {
                "type": "Action.ToggleVisibility",
                "title": "Show more data",
                "targetElements": ["moreData"]
              }
            ]
          },
          {
            "type": "Container",
            "id": "moreData",
            "isVisible": false,
            "items": [
              {
                "type": "TextBlock",
                "weight": "Bolder",
                "separator": true,
                "text": "Sprint Goal Progress"
              },
              {
                "type": "TextBlock",
                "wrap": true,
                "spacing": "None",
                "text": "{{themesBody}}"
              },
              {
                "type": "TextBlock",
                "weight": "Bolder",
                "separator": true,
                "text": "Progress & Burndown"
              },
              {
                "type": "FactSet",
                "facts": [
                  { "title": "Total", "value": "{{totalSP}} SP / {{issueCount}} issues" },
                  { "title": "Done", "value": "{{doneSP}} SP ({{pctComplete}}%) / {{doneCount}}" },
                  { "title": "In Progress (cat.)", "value": "{{inProgressSP}} SP ({{ipPct}}%) / {{ipCount}}{{wipWarning}}" },
                  { "title": "To Do", "value": "{{toDoSP}} SP ({{todoPct}}%) / {{todoCount}}" },
                  { "title": "Burndown", "value": "{{actualRemaining}} vs ideal {{idealRemaining}} SP ({{burndownDeltaPct}}%)" },
                  { "title": "Unestimated", "value": "{{unestimatedCount}}" },
                  { "title": "Tests excluded", "value": "{{testExcludedCount}} tickets, {{testExcludedSP}} SP" }
                ]
              },
              {
                "type": "TextBlock",
                "weight": "Bolder",
                "separator": true,
                "text": "Since Yesterday"
              },
              {
                "type": "TextBlock",
                "wrap": true,
                "spacing": "None",
                "text": "{{sinceYesterdayBody}}"
              },
              {
                "type": "TextBlock",
                "weight": "Bolder",
                "separator": true,
                "text": "Bottleneck — where the work actually is"
              },
              {
                "type": "TextBlock",
                "wrap": true,
                "spacing": "None",
                "text": "In-Progress {{devCount}} · In-Review {{reviewCount}} · QA {{qaCount}}"
              },
              {
                "type": "TextBlock",
                "wrap": true,
                "spacing": "None",
                "text": "{{bottleneckBody}}"
              },
              {
                "type": "TextBlock",
                "weight": "Bolder",
                "separator": true,
                "text": "Estimation & method notes"
              },
              {
                "type": "TextBlock",
                "wrap": true,
                "spacing": "None",
                "text": "{{estimationBody}}"
              },
              {
                "type": "TextBlock",
                "weight": "Bolder",
                "separator": true,
                "text": "All recommendations"
              },
              {
                "type": "TextBlock",
                "wrap": true,
                "spacing": "None",
                "text": "{{recommendationsBody}}"
              },
              {
                "type": "TextBlock",
                "isSubtle": true,
                "wrap": true,
                "separator": true,
                "text": "Roster: {{rosterLine}}"
              }
            ]
          }
        ]
      }
    }
  ]
}
