{
  "type": "message",
  "attachments": [
    {
      "contentType": "application/vnd.microsoft.card.adaptive",
      "content": {
        "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
        "type": "AdaptiveCard",
        "version": "1.5",
        "body": [
          {
            "type": "TextBlock",
            "size": "Large",
            "weight": "Bolder",
            "wrap": true,
            "text": "{{ragEmoji}} Sprint Health — {{sprintName}}"
          },
          {
            "type": "TextBlock",
            "isSubtle": true,
            "wrap": true,
            "spacing": "None",
            "text": "Day {{daysElapsed}}/{{sprintLength}} ({{daysRemaining}} left){{sprintStateSuffix}}"
          },
          {
            "type": "ColumnSet",
            "spacing": "Small",
            "columns": [
              {
                "type": "Column",
                "width": "stretch",
                "items": [
                  {
                    "type": "Container",
                    "style": "{{overallStyle}}",
                    "bleed": true,
                    "items": [
                      { "type": "TextBlock", "text": "Overall", "isSubtle": true, "spacing": "None", "wrap": true },
                      { "type": "TextBlock", "text": "{{overallStatus}}", "weight": "Bolder", "color": "{{overallColor}}", "spacing": "None", "wrap": true }
                    ]
                  }
                ]
              },
              {
                "type": "Column",
                "width": "stretch",
                "items": [
                  {
                    "type": "Container",
                    "style": "{{goalStyle}}",
                    "bleed": true,
                    "items": [
                      { "type": "TextBlock", "text": "Sprint goal", "isSubtle": true, "spacing": "None", "wrap": true },
                      { "type": "TextBlock", "text": "{{goalStatus}}", "weight": "Bolder", "color": "{{goalColor}}", "spacing": "None", "wrap": true }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Container",
            "style": "emphasis",
            "bleed": true,
            "items": [
              { "type": "TextBlock", "weight": "Bolder", "text": "TL;DR" },
              { "type": "TextBlock", "wrap": true, "spacing": "None", "text": "{{tldr}}" },
              { "type": "TextBlock", "wrap": true, "isSubtle": true, "text": "Verdict: {{oneLineVerdict}}" }
            ]
          },
          {
            "type": "TextBlock",
            "wrap": true,
            "text": "**Goal roll-up:** {{goalDoneSP}}/{{goalTotalSP}} SP ({{goalPct}}%) vs {{expectedPct}}% expected → {{goalVerdictEmoji}}"
          },
          {
            "type": "TextBlock",
            "weight": "Bolder",
            "style": "heading",
            "text": "What matters most"
          },
          {
            "type": "TextBlock",
            "wrap": true,
            "spacing": "None",
            "text": "{{whatMattersBody}}"
          },
          {
            "type": "TextBlock",
            "weight": "Bolder",
            "style": "heading",
            "text": "Top recommendations"
          },
          {
            "type": "FactSet",
            "facts": [
              { "title": "{{rec1Prio}} 1", "value": "{{rec1Text}}" },
              { "title": "{{rec2Prio}} 2", "value": "{{rec2Text}}" },
              { "title": "{{rec3Prio}} 3", "value": "{{rec3Text}}" }
            ]
          },
          {
            "type": "ActionSet",
            "actions": [
              {
                "type": "Action.ToggleVisibility",
                "title": "Show more data",
                "targetElements": ["moreData"]
              }
            ]
          },
          {
            "type": "Container",
            "id": "moreData",
            "isVisible": false,
            "items": [
              {
                "type": "TextBlock",
                "weight": "Bolder",
                "style": "heading",
                "separator": true,
                "text": "Sprint goal progress"
              },
              {
                "type": "ColumnSet",
                "separator": true,
                "columns": [
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "Theme", "weight": "Bolder", "wrap": true } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "SP", "weight": "Bolder" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "%", "weight": "Bolder" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "Status", "weight": "Bolder" } ] }
                ]
              },
              {
                "type": "ColumnSet",
                "columns": [
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "{{theme1Name}}", "wrap": true } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{theme1SP}}" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{theme1Pct}}" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{theme1Emoji}}", "color": "{{theme1Color}}" } ] }
                ]
              },
              {
                "type": "ColumnSet",
                "columns": [
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "{{theme2Name}}", "wrap": true } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{theme2SP}}" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{theme2Pct}}" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{theme2Emoji}}", "color": "{{theme2Color}}" } ] }
                ]
              },
              {
                "type": "ColumnSet",
                "columns": [
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "{{theme3Name}}", "wrap": true } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{theme3SP}}" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{theme3Pct}}" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{theme3Emoji}}", "color": "{{theme3Color}}" } ] }
                ]
              },
              {
                "type": "TextBlock",
                "weight": "Bolder",
                "style": "heading",
                "separator": true,
                "text": "Progress & burndown"
              },
              {
                "type": "FactSet",
                "facts": [
                  { "title": "Total", "value": "{{totalSP}} SP / {{issueCount}} issues" },
                  { "title": "Done", "value": "{{doneSP}} SP ({{pctComplete}}%) / {{doneCount}}" },
                  { "title": "In Progress (cat.)", "value": "{{inProgressSP}} SP ({{ipPct}}%) / {{ipCount}}{{wipWarning}}" },
                  { "title": "To Do", "value": "{{toDoSP}} SP ({{todoPct}}%) / {{todoCount}}" },
                  { "title": "Burndown", "value": "{{actualRemaining}} vs ideal {{idealRemaining}} SP ({{burndownDeltaPct}}%)" },
                  { "title": "Unestimated", "value": "{{unestimatedCount}}" },
                  { "title": "Tests", "value": "{{testsLine}}" }
                ]
              },
              {
                "type": "TextBlock",
                "weight": "Bolder",
                "style": "heading",
                "separator": true,
                "text": "Since yesterday ({{prevReportDate}})"
              },
              {
                "type": "FactSet",
                "facts": [
                  { "title": "✅ Completed", "value": "{{completedCount}} ({{spCompleted}} SP)" },
                  { "title": "▶ Advanced", "value": "{{startedCount}}" },
                  { "title": "↩ Sent back", "value": "{{sentBackCount}} ({{spSentBack}} SP)" },
                  { "title": "◀ Regressed", "value": "{{regressedCount}} ({{spRegressed}} SP)" },
                  { "title": "Scope", "value": "{{scopeLine}}" }
                ]
              },
              {
                "type": "TextBlock",
                "wrap": true,
                "spacing": "None",
                "isSubtle": true,
                "text": "{{sinceYesterdayNotable}}"
              },
              {
                "type": "TextBlock",
                "weight": "Bolder",
                "style": "heading",
                "separator": true,
                "text": "Bottleneck — where the work actually is"
              },
              {
                "type": "ColumnSet",
                "separator": true,
                "columns": [
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "Stage", "weight": "Bolder" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "Tickets", "weight": "Bolder" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "SP", "weight": "Bolder" } ] }
                ]
              },
              {
                "type": "ColumnSet",
                "columns": [
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "In-Progress (dev)" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{devCount}}" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{devSP}}" } ] }
                ]
              },
              {
                "type": "ColumnSet",
                "columns": [
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "In-Review" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{reviewCount}}" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{reviewSP}}" } ] }
                ]
              },
              {
                "type": "ColumnSet",
                "columns": [
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "QA" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{qaCount}}" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{qaSP}}" } ] }
                ]
              },
              {
                "type": "TextBlock",
                "weight": "Bolder",
                "spacing": "Medium",
                "text": "Longest-waiting review / QA"
              },
              {
                "type": "ColumnSet",
                "separator": true,
                "columns": [
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "Key", "weight": "Bolder" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "Queue", "weight": "Bolder" } ] },
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "Idle since", "weight": "Bolder" } ] }
                ]
              },
              {
                "type": "ColumnSet",
                "columns": [
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{wait1Key}}" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{wait1Queue}}" } ] },
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "{{wait1Idle}}", "wrap": true } ] }
                ]
              },
              {
                "type": "ColumnSet",
                "columns": [
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{wait2Key}}" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{wait2Queue}}" } ] },
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "{{wait2Idle}}", "wrap": true } ] }
                ]
              },
              {
                "type": "ColumnSet",
                "columns": [
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{wait3Key}}" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{wait3Queue}}" } ] },
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "{{wait3Idle}}", "wrap": true } ] }
                ]
              },
              {
                "type": "ColumnSet",
                "columns": [
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{wait4Key}}" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{wait4Queue}}" } ] },
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "{{wait4Idle}}", "wrap": true } ] }
                ]
              },
              {
                "type": "ColumnSet",
                "columns": [
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{wait5Key}}" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{wait5Queue}}" } ] },
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "{{wait5Idle}}", "wrap": true } ] }
                ]
              },
              {
                "type": "TextBlock",
                "wrap": true,
                "spacing": "Small",
                "isSubtle": true,
                "text": "{{bottleneckNote}}"
              },
              {
                "type": "TextBlock",
                "weight": "Bolder",
                "style": "heading",
                "separator": true,
                "text": "All recommendations"
              },
              {
                "type": "ColumnSet",
                "separator": true,
                "columns": [
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "#", "weight": "Bolder" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "Prio", "weight": "Bolder" } ] },
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "Action / owners", "weight": "Bolder" } ] }
                ]
              },
              {
                "type": "ColumnSet",
                "columns": [
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "1" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{rec1Prio}}" } ] },
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "{{rec1Full}}", "wrap": true } ] }
                ]
              },
              {
                "type": "ColumnSet",
                "columns": [
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "2" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{rec2Prio}}" } ] },
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "{{rec2Full}}", "wrap": true } ] }
                ]
              },
              {
                "type": "ColumnSet",
                "columns": [
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "3" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{rec3Prio}}" } ] },
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "{{rec3Full}}", "wrap": true } ] }
                ]
              },
              {
                "type": "ColumnSet",
                "columns": [
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "4" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{rec4Prio}}" } ] },
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "{{rec4Full}}", "wrap": true } ] }
                ]
              },
              {
                "type": "ColumnSet",
                "columns": [
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "5" } ] },
                  { "type": "Column", "width": "auto", "items": [ { "type": "TextBlock", "text": "{{rec5Prio}}" } ] },
                  { "type": "Column", "width": "stretch", "items": [ { "type": "TextBlock", "text": "{{rec5Full}}", "wrap": true } ] }
                ]
              },
              {
                "type": "TextBlock",
                "isSubtle": true,
                "wrap": true,
                "separator": true,
                "text": "Roster: {{rosterLine}}"
              }
            ]
          }
        ]
      }
    }
  ]
}
